FROM python:latest

# swagger-coverage's report generator is a Java CLI, so a JRE is required
# for reporter.generate_report() to produce the HTML report.
RUN apt-get update \
    && apt-get install -y --no-install-recommends default-jre-headless \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip3 install poetry

COPY pyproject.toml poetry.lock ./

RUN poetry install --no-root

COPY . .

# Run the suite with swagger coverage enabled. On Linux the ":" in the
# host:port output directory is valid (unlike Windows), so the report is
# produced successfully.
#
# The project directory is bind-mounted at runtime (so the HTML report is
# written back to the host), which shadows the image's .venv. Re-run
# `poetry install` at startup to ensure a valid Linux virtualenv exists in
# the anonymous `/app/.venv` volume before invoking pytest.
CMD ["sh", "-c", "poetry install --no-root && poetry run pytest tests --swagger-coverage"]
